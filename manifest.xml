                      <Icon><bt:Image size="16" resid="ico.condreg.16"/><bt:Image size="32" resid="ico.condreg.32"/><bt:Image size="80" resid="ico.condreg.80"/></Icon>
                      <Action xsi:type="ExecuteFunction"><FunctionName>cmdCondRegion</FunctionName></Action>
                    </Item>
                    <Item id="itemAllFields">
                      <Label resid="lbl.allfields"/>
                      <Supertip><Title resid="lbl.allfields"/><Description resid="tip.allfields"/></Supertip>
                      <Icon><bt:Image size="16" resid="ico.allfields.16"/><bt:Image size="32" resid="ico.allfields.32"/><bt:Image size="80" resid="ico.allfields.80"/></Icon>
