        <bt:Image id="ico.pivot.80"        DefaultValue="https://localhost:3000/images/ico-pivot-80.png"/>
        <bt:Image id="ico.allfields.16"    DefaultValue="https://localhost:3000/images/ico-allfields-16.png"/>
        <bt:Image id="ico.allfields.32"    DefaultValue="https://localhost:3000/images/ico-allfields-32.png"/>
        <bt:Image id="ico.allfields.80"    DefaultValue="https://localhost:3000/images/ico-allfields-80.png"/>
        <bt:Image id="ico.tableform.16"    DefaultValue="https://localhost:3000/images/ico-tableform-16.png"/>
        <bt:Image id="ico.tableform.32"    DefaultValue="https://localhost:3000/images/ico-tableform-32.png"/>
        <bt:Image id="ico.tableform.80"    DefaultValue="https://localhost:3000/images/ico-tableform-80.png"/>
