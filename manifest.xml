    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>

          <GetStarted>
            <Title resid="getStarted.Title"/>
            <Description resid="getStarted.Desc"/>
            <LearnMoreUrl resid="url.taskpane"/>
          </GetStarted>

          <FunctionFile resid="url.commands"/>

          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="TabPublisher">

              <!-- ============ LOAD DATA (2 controls) ============ -->
              <Group id="grpLoadData">
                <Label resid="grp.data"/>
                <Icon><bt:Image size="16" resid="ico.samplexml.16"/><bt:Image size="32" resid="ico.samplexml.32"/><bt:Image size="80" resid="ico.samplexml.80"/></Icon>

                <Control xsi:type="Button" id="btnSampleXML">
                  <Label resid="lbl.samplexml"/>
                  <Supertip><Title resid="lbl.samplexml"/><Description resid="tip.samplexml"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.samplexml.16"/><bt:Image size="32" resid="ico.samplexml.32"/><bt:Image size="80" resid="ico.samplexml.80"/></Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>BIP</TaskpaneId>
                    <SourceLocation resid="url.samplexml"/>
                  </Action>
                </Control>

                <Control xsi:type="Button" id="btnXMLSchema">
                  <Label resid="lbl.xmlschema"/>
                  <Supertip><Title resid="lbl.xmlschema"/><Description resid="tip.xmlschema"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.xmlschema.16"/><bt:Image size="32" resid="ico.xmlschema.32"/><bt:Image size="80" resid="ico.xmlschema.80"/></Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>BIP</TaskpaneId>
                    <SourceLocation resid="url.xmlschema"/>
                  </Action>
                </Control>
              </Group>

              <!-- ============ INSERT (5 buttons + 1 menu = 6) ============ -->
              <Group id="grpInsert">
                <Label resid="grp.insert"/>
                <Icon><bt:Image size="16" resid="ico.field.16"/><bt:Image size="32" resid="ico.field.32"/><bt:Image size="80" resid="ico.field.80"/></Icon>

