              <Control xsi:type="Button" id="ctxCondRegion">
                <Label resid="lbl.ctx.condreg"/>
                <Supertip><Title resid="lbl.ctx.condreg"/><Description resid="tip.ctx.condreg"/></Supertip>
                <Icon><bt:Image size="16" resid="ico.condreg.16"/><bt:Image size="32" resid="ico.condreg.32"/><bt:Image size="80" resid="ico.condreg.80"/></Icon>
                <Action xsi:type="ExecuteFunction"><FunctionName>cmdWrapConditionalRegion</FunctionName></Action>
              </Control>
              <Control xsi:type="Button" id="ctxCondFmt">
                <Label resid="lbl.ctx.condfmt"/>
                <Supertip><Title resid="lbl.ctx.condfmt"/><Description resid="tip.ctx.condfmt"/></Supertip>
                <Icon><bt:Image size="16" resid="ico.condfmt.16"/><bt:Image size="32" resid="ico.condfmt.32"/><bt:Image size="80" resid="ico.condfmt.80"/></Icon>
                <Action xsi:type="ExecuteFunction"><FunctionName>cmdWrapConditionalFormat</FunctionName></Action>
              </Control>
            </OfficeMenu>
          </ExtensionPoint>

        </DesktopFormFactor>
