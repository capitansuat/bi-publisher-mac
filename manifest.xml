                      <Icon><bt:Image size="16" resid="ico.condfmt.16"/><bt:Image size="32" resid="ico.condfmt.32"/><bt:Image size="80" resid="ico.condfmt.80"/></Icon>
                      <Action xsi:type="ExecuteFunction"><FunctionName>cmdCondFormat</FunctionName></Action>
                    </Item>
                    <Item id="itemCondReg">
                      <Label resid="lbl.condreg"/>
