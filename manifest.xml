<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="TaskPaneApp">

  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>BI Publisher Tools</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="BI Publisher"/>
  <Description DefaultValue="Oracle BI Publisher Template Builder for macOS — design report templates in Word."/>
  <IconUrl DefaultValue="https://localhost:3000/images/ico-field-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/images/ico-field-80.png"/>
  <SupportUrl DefaultValue="https://localhost:3000/taskpane.html"/>

  <Hosts><Host Name="Document"/></Hosts>
  <DefaultSettings><SourceLocation DefaultValue="https://localhost:3000/taskpane.html"/></DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
                    xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
                    xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>

          <GetStarted>
            <Title resid="getStarted.Title"/>
            <Description resid="getStarted.Desc"/>
            <LearnMoreUrl resid="url.taskpane"/>
          </GetStarted>

          <FunctionFile resid="url.commands"/>

          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="TabPublisher">

              <!-- ============ LOAD DATA ============ -->
              <Group id="grpLoadData">
                <Label resid="grp.data"/>
                <Icon><bt:Image size="16" resid="ico.samplexml.16"/><bt:Image size="32" resid="ico.samplexml.32"/><bt:Image size="80" resid="ico.samplexml.80"/></Icon>

                <Control xsi:type="Button" id="btnSampleXML">
                  <Label resid="lbl.samplexml"/>
                  <Supertip><Title resid="lbl.samplexml"/><Description resid="tip.samplexml"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.samplexml.16"/><bt:Image size="32" resid="ico.samplexml.32"/><bt:Image size="80" resid="ico.samplexml.80"/></Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>BIP</TaskpaneId>
                    <SourceLocation resid="url.samplexml"/>
                  </Action>
                </Control>

                <Control xsi:type="Button" id="btnXMLSchema">
                  <Label resid="lbl.xmlschema"/>
                  <Supertip><Title resid="lbl.xmlschema"/><Description resid="tip.xmlschema"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.xmlschema.16"/><bt:Image size="32" resid="ico.xmlschema.32"/><bt:Image size="80" resid="ico.xmlschema.80"/></Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>BIP</TaskpaneId>
                    <SourceLocation resid="url.xmlschema"/>
                  </Action>
                </Control>
              </Group>

              <!-- ============ INSERT (6 buttons) ============ -->
              <Group id="grpInsert">
                <Label resid="grp.insert"/>
                <Icon><bt:Image size="16" resid="ico.field.16"/><bt:Image size="32" resid="ico.field.32"/><bt:Image size="80" resid="ico.field.80"/></Icon>

                <Control xsi:type="Button" id="btnField">
                  <Label resid="lbl.field"/>
                  <Supertip><Title resid="lbl.field"/><Description resid="tip.field"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.field.16"/><bt:Image size="32" resid="ico.field.32"/><bt:Image size="80" resid="ico.field.80"/></Icon>
                  <Action xsi:type="ShowTaskpane"><TaskpaneId>BIP</TaskpaneId><SourceLocation resid="url.field"/></Action>
                </Control>

                <Control xsi:type="Button" id="btnAllFields">
                  <Label resid="lbl.allfields"/>
                  <Supertip><Title resid="lbl.allfields"/><Description resid="tip.allfields"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.allfields.16"/><bt:Image size="32" resid="ico.allfields.32"/><bt:Image size="80" resid="ico.allfields.80"/></Icon>
                  <Action xsi:type="ShowTaskpane"><TaskpaneId>BIP</TaskpaneId><SourceLocation resid="url.allfields"/></Action>
                </Control>

                <Control xsi:type="Button" id="btnTableForm">
                  <Label resid="lbl.tableform"/>
                  <Supertip><Title resid="lbl.tableform"/><Description resid="tip.tableform"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.tableform.16"/><bt:Image size="32" resid="ico.tableform.32"/><bt:Image size="80" resid="ico.tableform.80"/></Icon>
                  <Action xsi:type="ShowTaskpane"><TaskpaneId>BIP</TaskpaneId><SourceLocation resid="url.tableform"/></Action>
                </Control>
              </Group>

              <!-- ============ TEMPLATE (3 buttons) ============ -->
              <Group id="grpTemplate">
                <Label resid="grp.template"/>
                <Icon><bt:Image size="16" resid="ico.repgroup.16"/><bt:Image size="32" resid="ico.repgroup.32"/><bt:Image size="80" resid="ico.repgroup.80"/></Icon>

                <Control xsi:type="Button" id="btnRepGroup">
                  <Label resid="lbl.repgroup"/>
                  <Supertip><Title resid="lbl.repgroup"/><Description resid="tip.repgroup"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.repgroup.16"/><bt:Image size="32" resid="ico.repgroup.32"/><bt:Image size="80" resid="ico.repgroup.80"/></Icon>
                  <Action xsi:type="ShowTaskpane"><TaskpaneId>BIP</TaskpaneId><SourceLocation resid="url.repgroup"/></Action>
                </Control>

                <Control xsi:type="Button" id="btnCondFmt">
                  <Label resid="lbl.condfmt"/>
                  <Supertip><Title resid="lbl.condfmt"/><Description resid="tip.condfmt"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.condfmt.16"/><bt:Image size="32" resid="ico.condfmt.32"/><bt:Image size="80" resid="ico.condfmt.80"/></Icon>
                  <Action xsi:type="ShowTaskpane"><TaskpaneId>BIP</TaskpaneId><SourceLocation resid="url.condfmt"/></Action>
                </Control>

                <Control xsi:type="Button" id="btnCondReg">
                  <Label resid="lbl.condreg"/>
                  <Supertip><Title resid="lbl.condreg"/><Description resid="tip.condreg"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.condreg.16"/><bt:Image size="32" resid="ico.condreg.32"/><bt:Image size="80" resid="ico.condreg.80"/></Icon>
                  <Action xsi:type="ShowTaskpane"><TaskpaneId>BIP</TaskpaneId><SourceLocation resid="url.condreg"/></Action>
                </Control>
              </Group>

              <!-- ============ OPTIONS (2 buttons) ============ -->
              <Group id="grpOptions">
                <Label resid="grp.options"/>
                <Icon><bt:Image size="16" resid="ico.options.16"/><bt:Image size="32" resid="ico.options.32"/><bt:Image size="80" resid="ico.options.80"/></Icon>

                <Control xsi:type="Button" id="btnOptions">
                  <Label resid="lbl.options"/>
                  <Supertip><Title resid="lbl.options"/><Description resid="tip.options"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.options.16"/><bt:Image size="32" resid="ico.options.32"/><bt:Image size="80" resid="ico.options.80"/></Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>BIP</TaskpaneId>
                    <SourceLocation resid="url.options"/>
                  </Action>
                </Control>

                <Control xsi:type="Button" id="btnAbout">
                  <Label resid="lbl.about"/>
                  <Supertip><Title resid="lbl.about"/><Description resid="tip.about"/></Supertip>
                  <Icon><bt:Image size="16" resid="ico.about.16"/><bt:Image size="32" resid="ico.about.32"/><bt:Image size="80" resid="ico.about.80"/></Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>BIP</TaskpaneId>
                    <SourceLocation resid="url.about"/>
                  </Action>
                </Control>
              </Group>

              <Label resid="tab.publisher"/>
            </CustomTab>
          </ExtensionPoint>


        </DesktopFormFactor>
      </Host>
    </Hosts>

