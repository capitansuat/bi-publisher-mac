                      <Supertip><Title resid="lbl.tableform"/><Description resid="tip.tableform"/></Supertip>
                      <Icon><bt:Image size="16" resid="ico.tableform.16"/><bt:Image size="32" resid="ico.tableform.32"/><bt:Image size="80" resid="ico.tableform.80"/></Icon>
                      <Action xsi:type="ExecuteFunction"><FunctionName>cmdTableForm</FunctionName></Action>
                    </Item>
                    <Item id="itemRepGroup">
                      <Label resid="lbl.repgroup"/>
                      <Supertip><Title resid="lbl.repgroup"/><Description resid="tip.repgroup"/></Supertip>
