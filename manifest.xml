          <!-- Right-click context menu: individual buttons (Mac compatible) -->
          <ExtensionPoint xsi:type="ContextMenu">
            <OfficeMenu id="ContextMenuText">
              <Control xsi:type="Button" id="ctxFieldProps">
                <Label resid="lbl.ctx.props"/>
                <Supertip><Title resid="lbl.ctx.props"/><Description resid="tip.ctx.props"/></Supertip>
                <Icon><bt:Image size="16" resid="ico.fieldbrowser.16"/><bt:Image size="32" resid="ico.fieldbrowser.32"/><bt:Image size="80" resid="ico.fieldbrowser.80"/></Icon>
                <Action xsi:type="ExecuteFunction"><FunctionName>cmdFieldProperties</FunctionName></Action>
              </Control>
              <Control xsi:type="Button" id="ctxInsertField">
                <Label resid="lbl.ctx.field"/>
                <Supertip><Title resid="lbl.ctx.field"/><Description resid="tip.ctx.field"/></Supertip>
                <Icon><bt:Image size="16" resid="ico.field.16"/><bt:Image size="32" resid="ico.field.32"/><bt:Image size="80" resid="ico.field.80"/></Icon>
                <Action xsi:type="ExecuteFunction"><FunctionName>cmdInsertFieldAtSelection</FunctionName></Action>
              </Control>
              <Control xsi:type="Button" id="ctxRepGroup">
                <Label resid="lbl.ctx.repgroup"/>
