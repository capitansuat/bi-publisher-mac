                  <Icon><bt:Image size="16" resid="ico.about.16"/><bt:Image size="32" resid="ico.about.32"/><bt:Image size="80" resid="ico.about.80"/></Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>BIP</TaskpaneId>
                    <SourceLocation resid="url.about"/>
                  </Action>
                </Control>
              </Group>

