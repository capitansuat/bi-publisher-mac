        <bt:Image id="ico.repgroup.32"     DefaultValue="https://localhost:3000/images/ico-repgroup-32.png"/>
        <bt:Image id="ico.repgroup.80"     DefaultValue="https://localhost:3000/images/ico-repgroup-80.png"/>
