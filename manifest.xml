        <bt:Image id="ico.about.32"        DefaultValue="https://localhost:3000/images/ico-about-32.png"/>
        <bt:Image id="ico.about.80"        DefaultValue="https://localhost:3000/images/ico-about-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="url.commands"     DefaultValue="https://localhost:3000/commands.html"/>
        <bt:Url id="url.taskpane"     DefaultValue="https://localhost:3000/taskpane.html"/>
        <bt:Url id="url.samplexml"    DefaultValue="https://localhost:3000/taskpane.html?panel=sample-xml"/>
