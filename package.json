{
  "name": "bi-publisher-template-builder-mac",
  "version": "1.0.0",
  "description": "Oracle BI Publisher Template Builder - Cross Platform Edition for macOS",
  "private": true,
  "scripts": {
    "dev": "webpack serve --config webpack.config.js --mode development",
    "build": "webpack --config webpack.config.js --mode production",
    "build:hosted": "webpack --config webpack.config.js --mode production --env BASE_URL=$BASE_URL",
    "dev-certs": "office-addin-dev-certs install",
    "sideload": "office-addin-debugging start manifest.xml",
    "validate": "office-addin-manifest-validator manifest.xml",
    "deploy:gh-pages": "npm run build:hosted && gh-pages -d dist"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "jsbarcode": "^3.11.5"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "gh-pages": "^6.1.0",
    "html-loader": "^4.2.0",
    "html-webpack-plugin": "^5.5.3",
    "office-addin-debugging": "^5.0.0",
    "office-addin-dev-certs": "^1.11.0",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
